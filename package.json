{
  "name": "betsync",
  "version": "2.0.0",
  "description": "Sistema de Gerenciamento de Apostas Esportivas com PostgreSQL e Autenticação",
  "main": "backend/server-postgres.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node server-postgres.js",
    "dev:frontend": "cd frontend && npm start",
    "build": "cd frontend && npm install && npm run build",
    "start": "cd backend && node server-postgres.js",
    "start:backend": "cd backend && node server-postgres.js",
    "start:frontend": "cd frontend && npm start"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
